{
    "name": "libie",
    "version": "1.0.0",
    "description": "Libie - Advanced WhatsApp Bot",
    "type": "module",
    "license": "Apache-2.0",
    "author": {
        "name": "Himejima",
        "email": "noisyboyss887@gmail.com",
        "url": "https://github.com/darrma23"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/darrma23/libie.git"
    },
    "homepage": "https://github.com/darrma23/libie#readme",
    "bugs": {
        "url": "https://github.com/darrma23/libie/issues"
    },
    "engines": {
        "bun": ">=1.3.0"
    },
    "scripts": {
        "start": "bun run --smol src/main.js",
        "notify": "bun run notifserver.js",
        "lint": "eslint ."
    },
    "dependencies": {
        "@napi-rs/canvas": "^0.1.84",
        "async-mutex": "^0.5.0",
        "axios": "^1.13.6",
        "baileys": "github:naruyaizumi/baileys",
        "cheerio": "^1.2.0",
        "chokidar": "^5.0.0",
        "eventemitter3": "^5.0.1",
        "file-type": "^21.3.0",
        "node-webpmux": "^3.2.1",
        "p-queue": "^9.1.0",
        "redis": "^5.11.0",
        "sharp": "^0.34.5",
        "similarity": "^1.2.1",
        "translate-google-api": "^1.0.4"
    },
    "imports": {
        "#api/*": "./src/lib/api/*",
        "#canvas/*": "./src/lib/canvas/*",
        "#auth": "./src/lib/core/auth/auth.js",
        "#core/*": "./src/lib/core/*",
        "#lib/*": "./src/lib/*",
        "#db": "./src/lib/database.js"
    },
    "prettier": {
        "printWidth": 100,
        "tabWidth": 4,
        "useTabs": false,
        "semi": true,
        "singleQuote": false,
        "quoteProps": "as-needed",
        "jsxSingleQuote": false,
        "trailingComma": "es5",
        "bracketSpacing": true,
        "bracketSameLine": false,
        "arrowParens": "always",
        "endOfLine": "lf",
        "proseWrap": "preserve",
        "htmlWhitespaceSensitivity": "css",
        "embeddedLanguageFormatting": "auto"
    },
    "trustedDependencies": [
        "baileys",
        "protobufjs",
        "sharp"
    ],
    "devDependencies": {
        "prettier": "^3.8.0"
    }
}
