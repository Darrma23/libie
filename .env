# ============================================
# Libie WhatsApp Bot - Configuration Template
# ============================================
# Copy this file to `.env` and fill in your values
# ============================================

# ============================================
# STAFF CONFIGURATION
# ============================================
# Format: ["lid1","lid2"]
# Use native WhatsApp LIDs, NOT phone numbers
# Example: ["113748182302861","227551947555018"]
OWNERS=["8126732484745"]

# ============================================
# PAIRING CONFIGURATION
# ============================================
# Phone number for pairing (country code without + or spaces)
# Example: 6283143663697
PAIRING_NUMBER=6281933732553

# Custom pairing code (8 alphanumeric characters, auto-generated if empty)
PAIRING_CODE=LIBIEBOT

# ============================================
# BOT METADATA
# ============================================
# Bot watermark displayed in messages
WATERMARK=Libie

# Bot author/owner name
AUTHOR=Himejima

# Default sticker pack name
STICKPACK=Libie

# Default sticker author name
STICKAUTH=© Himejima

# Default thumbnail URL for rich messages
THUMBNAIL_URL=https://files.catbox.moe/3s2119.jpg

# ============================================
# BOT BEHAVIOR CONFIGURATION
# ============================================
SELF=true

# ============================================
# LOGGER CONFIGURATION
# ============================================
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Enable pretty printing for logs
LOG_PRETTY=true

# Enable colored output in logs
LOG_COLORIZE=true

# Time format for log timestamps
LOG_TIME_FORMAT=HH:MM

# Log fields to ignore
LOG_IGNORE=pid,hostname

# Baileys library log level: silent, error, warn, info, debug, trace
BAILEYS_LOG_LEVEL=silent

# ============================================
# NOTES:
# ============================================
# 1. Copy this file to `.env` and configure your settings
# 2. LIDs (Local IDs) are WhatsApp's internal user identifiers
# 3. PAIRING_NUMBER must be in international format without + or spaces
# 4. PAIRING_CODE should be 8 alphanumeric characters
# 5. PREFIX must be a valid JSON array of strings
# 6. Keep sensitive information secure and never commit `.env` to version control